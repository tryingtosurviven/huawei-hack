{
  "manifest_version": 3,
  "name": "SafeSignal — AI Harm Pattern Recognition",
  "version": "1.3.0",
  "description": "Passively detects grooming, cyberbullying, scams and oversharing across WhatsApp, Telegram, and Instagram. Full Singlish/code-mixed support. Built for Singapore.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://web.telegram.org/*",
    "https://www.instagram.com/*",
    "https://api-inference.huggingface.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["core/singlish_detector.js", "adapters/whatsapp_adapter.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.telegram.org/*"],
      "js": ["core/singlish_detector.js", "adapters/telegram_adapter.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["core/singlish_detector.js", "adapters/instagram_adapter.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "styles.css",
        "assets/icon16.png",
        "assets/icon48.png",
        "assets/icon128.png"
      ],
      "matches": [
        "https://web.whatsapp.com/*",
        "https://web.telegram.org/*",
        "https://www.instagram.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}